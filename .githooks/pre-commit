#!/usr/bin/env bash
set -euo pipefail

repo="$(git rev-parse --show-toplevel)"
cd "$repo"

file=".claude/settings.json"

# Only format Claude settings when that file is staged.
if ! git diff --cached --quiet -- "$file"; then
  # Do not accidentally fold unstaged edits into the commit.
  if ! git diff --quiet -- "$file"; then
    echo "error: $file has unstaged changes; stage or stash them before committing." >&2
    exit 1
  fi

  if ! command -v jq >/dev/null 2>&1; then
    echo "error: jq is required to format $file." >&2
    exit 1
  fi

  tmp="$(mktemp)"
  trap 'rm -f "$tmp"' EXIT

  if ! jq -S . "$file" > "$tmp"; then
    echo "error: failed to format $file with jq -S; is it valid JSON?" >&2
    exit 1
  fi

  cat "$tmp" > "$file"
  git add "$file"

  echo "pre-commit: formatted $file with jq -S" >&2
fi

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "error: gitleaks is required to scan staged secrets; run ./install.sh or install gitleaks." >&2
  exit 1
fi

echo "pre-commit: scanning staged secrets with gitleaks" >&2
gitleaks git --pre-commit --staged --redact --verbose

echo "pre-commit: running ./scripts/test-install.sh" >&2
./scripts/test-install.sh

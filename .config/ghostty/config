theme = light:Catppuccin Latte,dark:Catppuccin Mocha

# Font
font-family = JetBrains Mono NL
font-size = 16
background-opacity = 0.97

# Window
window-padding-x = 7
window-padding-y = 7
resize-overlay = never

# Cursor styling + SSH session terminfo
# (all shell integration options must be passed together)
shell-integration-features = no-cursor,ssh-env

# Keyboard bindings
keybind = shift+enter=text:\x1b\r
keybind = cmd+h=text:\x00\x1b[D
keybind = cmd+j=text:\x00\x1b[B
keybind = cmd+k=text:\x00\x1b[A
keybind = cmd+l=text:\x00\x1b[C

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Mac OS specific
macos-option-as-alt = left
macos-titlebar-style = hidden

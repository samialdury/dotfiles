{
  "openIssue": {
    "path": "/bin/sh",
    "args": [
      "-c",
      "cd \"$LINEAR_WORK_DIR\" && /opt/homebrew/bin/workmux add \"$LINEAR_ISSUE_BRANCH_NAME\" --prompt \"$LINEAR_PROMPT\" 2>/dev/null || { /opt/homebrew/bin/workmux send \"$LINEAR_ISSUE_BRANCH_NAME\" \"$LINEAR_PROMPT\"; /opt/homebrew/bin/workmux open \"$LINEAR_ISSUE_BRANCH_NAME\"; }"
    ],
    "env": [
      "LINEAR_WORK_DIR",
      "LINEAR_ISSUE_BRANCH_NAME",
      "LINEAR_PROMPT"
    ]
  }
}

.DS_Store
*.log
**/__pycache__

# tmux
.config/tmux/plugins

# bat
.config/bat/themes/tokyonight.nvim

# fish — whole-dir symlinked into ~/.config/fish, so runtime state
# (conf.d/, completions/, fish_variables, private.fish, history, etc.)
# materializes here on the live machine. Whitelist only the tracked bits.
.config/fish/*
!.config/fish/config.fish
!.config/fish/functions/
!.config/fish/functions/**

# claude
.claude/projects/
.claude/todos/
.claude/statsig/
.claude/shell-snapshots/
.claude/history.jsonl
.claude/.credentials.json
.claude/settings.local.json
